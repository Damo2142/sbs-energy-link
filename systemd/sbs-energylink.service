[Unit]
Description=SBS EnergyLink - Main Service
Documentation=https://sbscontrols.com/energylink
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=root
WorkingDirectory=/opt/sbs-energylink
ExecStart=/usr/bin/python3 /opt/sbs-energylink/src/main.py
Restart=always
RestartSec=15
StandardOutput=journal
StandardError=journal
SyslogIdentifier=sbs-energylink

# Give network time to settle on boot
ExecStartPre=/bin/sleep 10

[Install]
WantedBy=multi-user.target
